<header class="px-5 sm:px-6 bg-bgr text-typ whitespace-nowrap" data-header
  x-init="$nextTick(() => { initDropdown($el, 'z-50 min-w-[calc(100%_+_24px)] absolute top-0 flex flex-col gap-0.5 shadow-2xl rounded-theme bg-bgr py-2 px-1.5 -ml-2 mt-11 opacity-0 invisible translate-y-1 transition-all') })">
  <div class="max-w-site mx-auto py-4 md:py-6 flex items-center justify-between relative">

    {{!-- Brand --}}
    <div class="justify-self-start" data-header-brand>
      <a class="flex items-center gap-2 font-semibold" href="{{@site.url}}" data-brand>
        {{> logo loading="eager"}}
      </a>
    </div>

    {{!-- Right side (navigation and sign in button) --}}
    <div class="ml-auto hidden md:flex items-center gap-12">

      <nav class="text-sm" data-nav="header">
        {{navigation
        ul_class="flex items-center gap-12"
        li_class="relative"
        a_class="py-2"
        }}
      </nav>

      {{#if @member}}
      <button class="px-4 py-2 rounded-theme bg-bgr-tone hover:bg-bgr-tone/80 text-sm font-semibold"
        data-portal="account">
        Account
      </button>
      {{else}}
      <a class="px-4 py-2 rounded-theme bg-[#5b4bb7] text-white text-sm font-semibold hover:opacity-90" href="/ghost/">
        Sign in
      </a>
      {{/if}}

    </div>

    {{!-- Member/User button --}}
    {{#if @member}}
    <button
      class="relative flex items-center justify-center size-8 md:size-9 hover:bg-bgr-tone cursor-pointer rounded-theme"
      data-portal="account" aria-label="{{@member.name}}">
      {{#if @member.avatar_image}}
      <img class="relative size-7 md:size-8 rounded-theme z-[2]" src="{{@member.avatar_image}}" alt="{{@member.name}}">
      {{/if}}
      {{>icon name="user" icon_class="absolute z-1 size-5 stroke-2 inset-1.5 md:inset-2"}}
    </button>
    {{/if}}

    {{!-- Menu button --}}
    <button
      class="flex flex-col items-center gap-1 size-8 p-1 md:p-2 md:size-9 justify-center rounded-theme group md:hidden transition-transform hover:bg-bgr-tone cursor-pointer"
      data-menu-toggle aria-label="{{t " Menu toggle"}}" aria-expanded="false" aria-haspopup="true" aria-controls="menu"
      @click="menuOpen = !menuOpen" :aria-expanded="menuOpen.toString()">
      <span class="relative pointer-events-none h-0.5 rounded-sm bg-typ w-4 transition-transform"
        :class="menuOpen ? 'rotate-45 translate-y-0.75' : ''"></span>
      <span class="relative pointer-events-none h-0.5 rounded-sm bg-typ w-4 transition-transform"
        :class="menuOpen ? '-rotate-45 -translate-y-0.75' : ''"></span>
    </button>
  </div>

  </div>
</header>