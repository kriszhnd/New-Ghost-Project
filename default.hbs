<!DOCTYPE html>
<html lang="{{@site.locale}}" :data-color-scheme="colorScheme" class="scroll-smooth" x-data="{ colorScheme: getColorScheme() }">
  <head>
    {{!-- Document Settings --}}
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    {{!-- Page Meta --}}
    <title>{{meta_title}}</title>

    {{!-- Mobile Meta --}}
    <meta name="HandheldFriendly" content="True" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    {{!-- Theme color --}}
    <meta name="theme-color" content="{{@site.accent_color}}">
    <meta name="color-scheme" content="light dark">
    <meta name="ghost-theme" content="Skeleton 0.10.0">
    
    {{!-- Font definitions --}}
    {{> fonts}}

    {{!-- Main theme scripts --}}
    <script type="module" src="{{asset 'built/app.js'}}"></script>

    {{!-- Styles --}}
    <link rel="stylesheet" type="text/css" href="{{asset 'built/app.css'}}" />

    {{!-- Theme config --}}
    {{> config}}

    {{!-- Functions --}}
    {{> functions}}

    {{!-- Block for styles --}}
    {{{block "head"}}}

    {{!-- Ghost outputs important style and meta data with this tag --}}
    {{ghost_head}}
  </head>
  <body class="{{body_class}} subpixel-antialiased relative overflow-x-hidden bg-bgr text-typ [&_.is-subitem]:hidden [&_.is-mainitem_.is-subitem]:flex"
    x-data="{ menuOpen: false, member: window.MEMBER }" :class="menuOpen ? 'overflow-hidden' : 'overflow-y-auto'"
    data-user="{{#if @member.paid}}paid-member{{else if @member}}free-member{{else}}visitor{{/if}}"
    @keydown.escape="menuOpen = false" @keydown.cmk.k="document.querySelector('[data-ghost-search]').click()"
    x-init="$nextTick(() => { socials = window.socials })"
  >
    {{!-- Skip to content --}}
    <a class="sr-only sr-only-focusable" href="#main">{{t "Skip to content"}}</a>
    
    {{!-- Progress Bar for posts --}}
    {{> progress-bar}}
    
    {{!-- Header --}}
    {{> header}}

    {{!-- All the main content gets inserted here, index.hbs, post.hbs, etc --}}
    <main class="main" id="main">
      {{{body}}}
    </main>

    {{!-- Footer --}}
    {{> footer}}

    {{!-- Dropdown toggle --}}
    {{> dropdown-toggle}}

    {{!-- Block for scripts --}}
    {{{block "body"}}}

    {{!-- Ghost outputs important scripts and data with this tag --}}
    {{ghost_foot}}
  </body>
</html>
