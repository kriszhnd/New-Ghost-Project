{{!< default}}

{{#post}}
  <section class="px-5 sm:px-6 my-8">
    <div class="max-w-content mx-auto">
      <h1 class="font-bold text-xl sm:text-2xl md:text-3xl lg:text-4xl">{{title}}</h1>
    </div>
  </section>

  <article class="ghost-content prose md:prose-lg prose-theme"{{#unless access}} data-preview{{/unless}}>
    {{content}}
  </article>
{{/post}}
