{
  "name": "skeleton",
  "description": "Skeleton Ghost Theme",
  "version": "0.10.0",
  "engines": {
    "ghost": ">=6.0.0"
  },
  "type": "module",
  "author": {
    "name": "Bright Themes",
    "email": "hi@brightthemes.com",
    "url": "https://brightthemes.com"
  },
  "gpm": {
    "type": "theme",
    "categories": [
      "Blog"
    ]
  },
  "keywords": [
    "ghost",
    "theme",
    "ghost-theme"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/brightthemes/skeleton.git"
  },
  "scripts": {
    "dev": "vite build --watch & vite",
    "serve": "vite",
    "watch": "vite build --watch",
    "prebuild": "test -f theme.js && node theme.js || true",
    "build": "vite build",
    "preview": "vite preview",
    "test": "gscan . --verbose",
    "zip": "npm run build && npm run test && mkdir -p dist && zip -r dist/${npm_package_name} . -x 'dist*' 'demo*' 'node_modules*' '.*' 'TODO.md' 'private.hbs' 'theme.js'",
    "release": "npm version minor --no-git-tag-version && npm run zip && git add . && git commit -m \"v$(node -p 'require(\"./package.json\").version')\" && git push"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@tryghost/content-api": "^1.12.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "alpinejs": "^3.15.0",
    "gscan": "^5.1.0",
    "tailwindcss": "^4.0.0",
    "tocbot": "^4.36.4",
    "vite": "^7.1.9"
  },
  "config": {
    "card_assets": true,
    "posts_per_page": 12,
    "image_sizes": {
      "xxs": {
        "width": 30
      },
      "xs": {
        "width": 100
      },
      "s": {
        "width": 320
      },
      "m": {
        "width": 640
      },
      "l": {
        "width": 960
      },
      "xl": {
        "width": 1280
      },
      "xxl": {
        "width": 2000
      }
    },
    "custom": {
      "color_scheme": {
        "type": "select",
        "options": [
          "system",
          "light",
          "dark"
        ],
        "default": "system",
        "description": "Set the default color scheme of the site"
      },
      "dark_theme_logo": {
        "type": "image",
        "description": "Logo for the dark theme"
      }
    }
  }
}
